generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  accounts      Account[]
  sessions      Session[]
  Authenticator Authenticator[]
  missions      Mission[]
  calendarEvents CalendarEvent[]
  preferences   UserPreferences?
}

model UserPreferences {
  id                   String   @id @default(uuid())
  userId               String   @unique
  workDayStart         Int      @default(9)
  workDayEnd           Int      @default(18)
  preferredFocusWindow String   @default("Morning")
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Mission {
  id               String               @id @default(uuid())
  title            String
  description      String?
  date             DateTime?
  startTime        DateTime?
  endTime          DateTime?
  estimatedMinutes Int?
  actualMinutes    Int                  @default(0)
  energyRequired   String               @default("Medium")
  isAIScheduled    Boolean              @default(false)
  type             String               @default("Focus")
  priority         String               @default("Low")
  status           String               @default("Pending")
  category         String?
  context          String?
  preferredTime    String?
  notes            String?
  color            String               @default("Red")
  tags             String?
  recurringRule    String?
  missionScore     Int                  @default(50)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  userId           String?
  user             User?                @relation(fields: [userId], references: [id])
  activities       MissionActivity[]
  insight          MissionInsight?
  suggestions      ScheduleSuggestion[]
  scheduledBlocks  ScheduledBlock[]
  subMissions      SubMission[]
  workSessions     WorkSession[]
  Mission_A        Mission[]            @relation("MissionDependencies")
  Mission_B        Mission[]            @relation("MissionDependencies")
}

model SubMission {
  id               String   @id @default(uuid())
  title            String
  description      String?
  estimatedMinutes Int?
  actualMinutes    Int      @default(0)
  difficulty       String   @default("Medium")
  energyLevel      String   @default("Medium")
  priority         String   @default("Medium")
  dependencies     String?
  status           String   @default("Pending")
  order            Int      @default(0)
  missionId        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  mission          Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
}

model ScheduledBlock {
  id        String   @id @default(uuid())
  title     String
  startTime DateTime
  endTime   DateTime
  source    String   @default("USER")
  type      String   @default("Focus")
  missionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  mission   Mission? @relation(fields: [missionId], references: [id])
}

model WorkSession {
  id              String    @id @default(uuid())
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  energyRating    Int?
  focusScore      Int?
  missionId       String
  createdAt       DateTime  @default(now())
  mission         Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
}

model MissionInsight {
  id              String   @id @default(uuid())
  missionId       String   @unique
  keyRisks        String
  recommendations String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  mission         Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
}

model ScheduleSuggestion {
  id             String   @id @default(uuid())
  missionId      String
  suggestedStart DateTime
  suggestedEnd   DateTime
  reasoning      String
  status         String   @default("Pending")
  createdAt      DateTime @default(now())
  mission        Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id            String   @id @default(uuid())
  title         String
  description   String?
  location      String?
  startTime     DateTime
  endTime       DateTime
  recurringRule String?
  attendees     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
}

model MissionActivity {
  id        String   @id @default(uuid())
  missionId String
  action    String
  createdAt DateTime @default(now())
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}
